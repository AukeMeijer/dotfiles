font-family = MesloLGS Nerd Font Mono
#font-family = Iosevka Nerd Font
#font-family = SFMono Nerd Font
font-size   = 20
theme       = Gruvbox Dark Hard
cursor-style = block

#shell-integration-features = no-cursor,sudo,no-title
#adjust-cell-height = 35%

mouse-hide-while-typing = true
mouse-scroll-multiplier = 2

window-padding-x = 0
window-padding-y = 0

#window-padding-balance   = true
window-save-state        = always
#window-decoration        = none
#macos-non-native-fullscreen = true
#macos-titlebar-style     = transparent
macos-option-as-alt      = true
fullscreen               = true
window-colorspace        = "display-p3"
background               = #282828
background-opacity       = 0.9
background-blur          = 50

# Window split separator (lighter than background)
split-divider-color = #928374

#foreground = d4be98

# keybindings (Leader: Ctrl+B - tmux-style, avoids conflicts)
keybind = ctrl+b>r=reload_config
keybind = ctrl+b>x=close_surface
keybind = ctrl+b>f=toggle_fullscreen
keybind = ctrl+b>n=new_window

# tabs
keybind = ctrl+b>c=new_tab
keybind = ctrl+b>shift+l=next_tab
keybind = ctrl+b>shift+h=previous_tab
keybind = ctrl+b>comma=move_tab:-1
keybind = ctrl+b>period=move_tab:1

# quick tab switch
keybind = ctrl+b>1=goto_tab:1
keybind = ctrl+b>2=goto_tab:2
keybind = ctrl+b>3=goto_tab:3
keybind = ctrl+b>4=goto_tab:4
keybind = ctrl+b>5=goto_tab:5
keybind = ctrl+b>6=goto_tab:6
keybind = ctrl+b>7=goto_tab:7
keybind = ctrl+b>8=goto_tab:8
keybind = ctrl+b>9=goto_tab:9

# split
keybind = ctrl+b>\=new_split:right
keybind = ctrl+b>-=new_split:down
keybind = ctrl+b>j=goto_split:bottom
keybind = ctrl+b>k=goto_split:top
keybind = ctrl+b>h=goto_split:left
keybind = ctrl+b>l=goto_split:right
keybind = ctrl+b>z=toggle_split_zoom
keybind = ctrl+b>e=equalize_splits

# other
copy-on-select = clipboard
keybind        = shift+enter=text:\x1b\r
